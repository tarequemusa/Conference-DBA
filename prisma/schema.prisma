generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Roles for access control
enum UserRole {
  RESEARCHER
  REVIEWER
  ADMIN
  AUTHORITY
}

// Paper progression status
enum ProcessStatus {
  ABSTRACT_SUBMISSION
  INITIAL_EVALUATION
  ACCEPTANCE_NOTIFICATION
  PAYMENT_PENDING
  CONFIRMED
  FULL_PAPER_SUBMISSION
  PEER_REVIEW
  REVISION_REQUIRED
  FINAL_DECISION
  REJECTED                // Added for Authority Rejection
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?   // Profile Photo URL
  password      String?   // Hashed password (null for Google users)
  signature     String?   @db.Text // Stores base64 signature image
  role          UserRole  @default(RESEARCHER)

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  abstracts Abstract[]
  reviews   Review[]   @relation("ReviewerDocs")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Abstract {
  id        String        @id @default(cuid())
  title     String
  coAuthors String?
  abstract  String        @db.Text
  status        String    @default("ABSTRACT_SUBMISSION")

  // Payment tracking fields
  isPaid          Boolean @default(false)
  paymentAmount   Float?
  transactionId String?   // For SSL Commerz later
  stripeSessionId String? @unique
  fullPaperUrl    String?   // URL to the PDF/Doc file

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews    Review[]
  
  // Link to the specific reviewer assigned
  reviewerId String?
}

model Review {
  id              String  @id @default(cuid())
  
  // Rubric Scores
  originality    Int     @default(0)
  methodology    Int     @default(0)
  relevance      Int     @default(0)
  clarity        Int     @default(0)
  totalScore     Int     @default(0)
  
  comments       String  @db.Text
  recommendation String? // e.g., "ACCEPT", "REJECT"
  isFinal        Boolean @default(false)

  reviewerId String
  reviewer   User     @relation("ReviewerDocs", fields: [reviewerId], references: [id])
  abstractId String   // Changed from @unique to allow multiple reviewers if needed later
  abstract   Abstract @relation(fields: [abstractId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Ensure one reviewer can only review an abstract once
  @@unique([reviewerId, abstractId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String   // e.g., "ROLE_CHANGE", "ABSTRACT_ASSIGNED"
  details     String   // e.g., "Changed role of user@email.com to ADMIN"
  adminId     String
  adminName   String
  targetId    String?  // The user or abstract being affected
  createdAt   DateTime @default(now())
}


model SystemSettings {
  id                Int      @id @default(1)
  isSubmissionOpen  Boolean  @default(true)
  conferenceDate    DateTime @default("2026-05-20T00:00:00Z")
  registrationFee   Float    @default(150.00)
  updatedAt         DateTime @updatedAt
}