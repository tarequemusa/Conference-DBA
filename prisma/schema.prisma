generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole   @default(RESEARCHER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  signature     String?
  abstracts     Abstract[]
  accounts      Account[]
  reviews       Review[]   @relation("ReviewerDocs")
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Abstract {
  id              String   @id @default(cuid())
  title           String
  coAuthors       String?
  abstract        String
  isPaid          Boolean  @default(false)
  paymentAmount   Float?
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  reviewerId      String?
  fullPaperUrl    String?
  transactionId   String?
  status          String   @default("ABSTRACT_SUBMISSION")
  scheduledSlot   String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews         Review[]
}

model Review {
  id             String   @id @default(cuid())
  originality    Int      @default(0)
  methodology    Int      @default(0)
  relevance      Int      @default(0)
  clarity        Int      @default(0)
  totalScore     Int      @default(0)
  comments       String
  recommendation String?
  isFinal        Boolean  @default(false)
  reviewerId     String
  abstractId     String
  createdAt      DateTime @default(now())
  abstract       Abstract @relation(fields: [abstractId], references: [id], onDelete: Cascade)
  reviewer       User     @relation("ReviewerDocs", fields: [reviewerId], references: [id])

  @@unique([reviewerId, abstractId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String
  adminId   String
  adminName String
  targetId  String?
  createdAt DateTime @default(now())
}

model SystemSettings {
  id               Int      @id @default(1)
  isSubmissionOpen Boolean  @default(true)
  conferenceDate   DateTime @default(dbgenerated("'2026-05-20 00:00:00'::timestamp without time zone"))
  registrationFee  Float    @default(150.00)
  updatedAt        DateTime @updatedAt
}

enum UserRole {
  RESEARCHER
  REVIEWER
  ADMIN
  AUTHORITY
}

enum ProcessStatus {
  ABSTRACT_SUBMISSION
  INITIAL_EVALUATION
  ACCEPTANCE_NOTIFICATION
  PAYMENT_PENDING
  CONFIRMED
  FULL_PAPER_SUBMISSION
  PEER_REVIEW
  REVISION_REQUIRED
  FINAL_DECISION
  REJECTED
}
